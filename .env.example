# ============================================================
# CSS NIT Silchar - AGS Feedback Poll - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.

# -----------------------------------------------
# DATABASE (PostgreSQL via Neon, Supabase, or local)
# -----------------------------------------------
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/css_voting"

# -----------------------------------------------
# NEXTAUTH / AUTH.JS
# -----------------------------------------------
# Generate a secret: openssl rand -base64 32
AUTH_SECRET="your-super-secret-key-here-change-this"

# Your deployed URL (use http://localhost:3000 for local dev)
NEXTAUTH_URL="http://localhost:3000"
AUTH_URL="http://localhost:3000"

# -----------------------------------------------
# GOOGLE OAUTH
# -----------------------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Add Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# -----------------------------------------------
# ADMIN EMAILS (comma-separated, no spaces)
# -----------------------------------------------
ADMIN_EMAILS="soumya_ug_23@cse.nits.ac.in,jauhari_ug_23@cse.nits.ac.in"

# -----------------------------------------------
# ALLOWED EMAIL DOMAIN
# -----------------------------------------------
ALLOWED_EMAIL_DOMAIN="cse.nits.ac.in"
